              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "poolType",
            "required": true,
            "description": "pool type",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "concentrated",
                "standard",
                "allFarm",
                "concentratedFarm",
                "standardFarm"
              ]
            }
          },
          {
            "in": "query",
            "name": "poolSortField",
