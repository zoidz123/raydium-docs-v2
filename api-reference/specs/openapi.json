    },
    "/main/migrate-lp": {
      "get": {
        "summary": "Migrate LP Pool List",
        "description": "Get LP pools with migration guidance.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "pool symbol"
                      },
                      "ammId": {
                        "type": "string",
                        "description": "pool id"
                      },
                      "lpMint": {
                        "type": "string",
                        "description": "amm pool LP mint"
                      },
                      "farmIds": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "description": "farm pool id"
                        }
                      },
                      "clmmId": {
                        "type": "string",
                        "description": "pool id"
                      },
                      "defaultPriceMin": {
                        "type": "number",
                        "description": "defaultPriceMin"
                      },
                      "defaultPriceMax": {
                        "type": "number",
                        "description": "defaultPriceMax"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/main/auto-fee": {
      "get": {
        "summary": "Transaction Auto Fee",
        "description": "Get estimated on-chain fees based on recent transactions.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "default": {
                      "type": "object",
                      "properties": {
                        "m": {
                          "type": "number",
                          "description": "lower fee"
                        },
                        "h": {
                          "type": "number",
                          "description": "moderate fee"
                        },
                        "vh": {
                          "type": "number",
                          "description": "higher fee"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/main/clmm-config": {
      "get": {
        "summary": "CLMM Config",
        "description": "Get the CLMM configs allowed by the UI when creating a pool.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "config id"
                      },
                      "index": {
                        "type": "number",
                        "description": "config id pda index"
                      },
                      "protocolFeeRate": {
                        "type": "number",
                        "description": "protocol fee rate"
                      },
                      "tradeFeeRate": {
                        "type": "number",
                        "description": "trade fee rate"
                      },
                      "tickSpacing": {
                        "type": "number",
                        "description": "tick spacing"
                      },
                      "fundFeeRate": {
                        "type": "number",
                        "description": "fund fee rate"
                      },
                      "defaultRange": {
                        "type": "number",
                        "description": "default range"
                      },
                      "defaultRangePoint": {
                        "type": "array",
                        "items": {
                          "type": "number",
                          "description": "default range point"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/main/cpmm-config": {
      "get": {
        "summary": "CPMM Config",
        "description": "Get the CPMM configs allowed by the UI when creating a pool.",
        "tags": [
