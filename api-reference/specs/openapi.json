    "/main/mint-filter-config": {
      "get": {
        "summary": "Mint Filter Config",
        "description": "Get the mint filter configs allowed by the UI when creating a pool.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "row": {
                      "type": "array",
                      "description": "List of icon statistics",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "description": "The name of the item"
                          },
                          "icon": {
                            "type": "array",
                            "description": "A list of icon URLs or identifiers",
                            "items": {
                              "type": "string"
                            }
                          },
                          "count": {
                            "type": "integer",
                            "description": "The count associated with the item"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
