    "/pools/info/list": {
      "get": {
        "summary": "Pool Info List",
        "description": "Get a paginated list of pools.",
        "tags": [
          "Pools"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "poolType",
            "required": true,
            "description": "pool type",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "concentrated",
                "standard",
                "allFarm",
                "concentratedFarm",
                "standardFarm"
              ]
            }
          },
          {
            "in": "query",
            "name": "poolSortField",
            "required": true,
            "description": "pool field",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "liquidity",
                "volume24h",
                "fee24h",
                "apr24h",
                "volume7d",
                "fee7d",
                "apr7d",
                "volume30d",
                "fee30d",
                "apr30d"
              ]
            }
          },
          {
            "in": "query",
            "name": "sortType",
            "required": true,
            "description": "sort type",
            "schema": {
              "type": "string",
              "enum": [
                "desc",
                "asc"
              ]
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "page size, max 1000"
          },
          {
            "in": "query",
            "name": "page",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Page index."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
