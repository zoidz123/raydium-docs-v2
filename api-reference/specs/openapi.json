            "description": "pool field",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "liquidity",
                "volume24h",
                "fee24h",
                "apr24h",
                "volume7d",
                "fee7d",
                "apr7d",
                "volume30d",
                "fee30d",
                "apr30d"
              ]
            }
          },
          {
            "in": "query",
            "name": "sortType",
            "required": true,
            "description": "sort type",
            "schema": {
              "type": "string",
              "enum": [
                "desc",
