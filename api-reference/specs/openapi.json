        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "config id"
                      },
                      "index": {
                        "type": "number",
                        "description": "config id pda index"
                      },
                      "protocolFeeRate": {
                        "type": "number",
                        "description": "protocol fee rate"
                      },
                      "tradeFeeRate": {
                        "type": "number",
                        "description": "trade fee rate"
                      },
                      "fundFeeRate": {
                        "type": "number",
                        "description": "fund fee rate"
                      },
                      "createPoolFee": {
                        "type": "string",
                        "description": "create pool fee"
                      }
                    }
                  }
                }
              }
            }
          }
        }
