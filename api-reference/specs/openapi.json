                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pools/info/list-v2": {
      "get": {
        "summary": "Pool Info List V2",
        "description": "Get the V2 paginated pool list.",
        "tags": [
          "Pools"
        ],
        "parameters": [
          {
            "name": "poolType",
            "in": "query",
            "description": "Type of pool. Can be `Concentrated` or `Standard`. Optional \u2014 if not set, all types are returned.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Concentrated",
                "Standard"
              ]
            }
          },
          {
            "name": "mintFilter",
            "in": "query",
            "description": "Whether to filter by mint. Optional. please refer /main/mint-filter-config",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hasReward",
            "in": "query",
            "description": "Whether to return only pools that have rewards. Optional.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sortField",
            "in": "query",
            "description": "Field to sort by. Optional.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "liquidity",
                "volume24h",
                "fee24h",
                "apr24h",
                "volume7d",
                "fee7d",
                "apr7d",
                "volume30d",
                "fee30d",
                "apr30d"
              ]
            }
          },
          {
            "name": "sortType",
            "in": "query",
            "description": "Sorting order, either ascending (`asc`) or descending (`desc`). Optional.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of records to return per page.",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "nextPageId",
            "in": "query",
            "description": "The `id` returned from the previous page, used for pagination. Optional \u2014 if not provided, the first page is returned.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mint1",
