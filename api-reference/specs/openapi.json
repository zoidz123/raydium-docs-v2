                  }
                }
              }
            }
          }
        }
      }
    },
    "/main/info": {
      "get": {
        "summary": "TVL and 24-Hour Volume",
        "description": "Get total value locked and 24-hour volume statistics.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
