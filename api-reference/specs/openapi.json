{
  "openapi": "3.0.0",
  "info": {
    "title": "Raydium API V3",
    "version": "3.0.0",
    "description": "All APIs return a top-level status envelope. Successful responses use { id: string, success: true, data: object }. Failed responses use { id: string, success: false, msg: string }."
  },
  "tags": [
    {
      "name": "Pools",
      "description": "Pool data, keys, liquidity history, and CLMM position data."
    },
    {
      "name": "Mint",
      "description": "Mint metadata, lists, and pricing."
    },
    {
      "name": "Farms",
      "description": "Farm pool metadata and keys."
    },
    {
      "name": "IDO",
      "description": "IDO pool metadata and keys."
    },
    {
      "name": "Main",
      "description": "General UI, network, and configuration endpoints."
    }
  ],
  "paths": {
    "/farms/info/ids": {
      "get": {
        "summary": "Farm Pool Info",
        "description": "Get farm pool info by ID.",
        "tags": [
          "Farms"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "ids",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/farms/info/lp": {
      "get": {
        "summary": "Search Farm by LP Mint",
        "description": "Search farms by LP mint.",
        "tags": [
          "Farms"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "lp",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Stake LP mint address."
          },
          {
            "in": "query",
            "name": "pageSize",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Page size. Maximum 100."
          },
          {
            "in": "query",
            "name": "page",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Page index."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/farms/key/ids": {
      "get": {
        "summary": "Farm Pool Keys",
        "description": "Get farm pool keys by ID.",
        "tags": [
          "Farms"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "ids",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ido/key/ids": {
      "get": {
        "summary": "IDO Pool Keys",
        "description": "Get IDO pool keys by ID.",
        "tags": [
          "IDO"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "ids",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "programId": {
                      "type": "string",
                      "description": "The program ID."
                    },
                    "id": {
                      "type": "string",
                      "description": "The ID."
                    },
                    "authority": {
                      "type": "string",
                      "description": "The authority."
                    },
                    "projectInfo": {
                      "type": "object",
                      "description": "Project info.",
                      "properties": {
                        "mint": {
                          "type": "object",
                          "description": "Mint info."
                        },
                        "vault": {
                          "type": "string",
                          "description": "Vault address."
                        }
                      }
                    },
                    "buyInfo": {
                      "type": "object",
                      "description": "Buy info.",
                      "properties": {
                        "mint": {
                          "type": "object",
                          "description": "Mint info."
                        },
                        "vault": {
                          "type": "string",
                          "description": "Vault address."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/main/version": {
      "get": {
        "summary": "UI V3 Current Version",
        "description": "Get the current UI version.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "latest": {
                      "type": "string",
                      "description": "UI current version"
                    },
                    "least": {
                      "type": "string",
                      "description": "Minimum UI version number that users can use"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/main/rpcs": {
      "get": {
        "summary": "UI RPCs",
        "description": "Get the RPC endpoints used by the UI.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/main/chain-time": {
      "get": {
        "summary": "Chain Time",
        "description": "Get the chain time offset relative to local UTC time.",
        "tags": [
          "Main"
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "offset": {
                      "type": "integer",
                      "description": "local utc time - chain time"
